<mujoco model="panda_longhorizon_assembly">
  <include file="assets/panda.xml"/>

  <statistic center="0.3 0 0.4" extent="1.2"/>

  <visual>
    <headlight diffuse="0.8 0.8 0.8" ambient="0.4 0.4 0.4" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-30" offwidth="1280" offheight="720"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <material name="red_mat" rgba="0.9 0.1 0.1 1" reflectance="0.5"/>
    <material name="green_mat" rgba="0.1 0.9 0.1 1" reflectance="0.5"/>
    <material name="blue_mat" rgba="0.1 0.1 0.9 1" reflectance="0.5"/>
    <material name="yellow_mat" rgba="0.9 0.9 0.1 1" reflectance="0.5"/>
    <material name="target_red" rgba="0.9 0.1 0.1 0.3"/>
    <material name="target_green" rgba="0.1 0.9 0.1 0.3"/>
    <material name="target_blue" rgba="0.1 0.1 0.9 0.3"/>
    <material name="target_yellow" rgba="0.9 0.9 0.1 0.3"/>
    <material name="table_mat" rgba="0.3 0.25 0.2 1" reflectance="0.3"/>
    <material name="shelf_mat" rgba="0.4 0.35 0.3 1"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" directional="true" diffuse="0.7 0.7 0.7"/>
    <light pos="1 1 2" dir="-1 -1 -0.5" directional="true" diffuse="0.3 0.3 0.3"/>
    <light pos="-1 1 2" dir="1 -1 -0.5" directional="true" diffuse="0.2 0.2 0.2"/>

    <!-- Ground plane -->
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Work table -->
    <body name="table" pos="0.5 0 -0.05">
      <geom name="table_top" type="box" size="0.4 0.3 0.03" pos="0 0 0.08" material="table_mat"/>
      <geom name="table_leg1" type="box" size="0.02 0.02 0.08" pos="-0.35 -0.25 -0.08"/>
      <geom name="table_leg2" type="box" size="0.02 0.02 0.08" pos="0.35 -0.25 -0.08"/>
      <geom name="table_leg3" type="box" size="0.02 0.02 0.08" pos="-0.35 0.25 -0.08"/>
      <geom name="table_leg4" type="box" size="0.02 0.02 0.08" pos="0.35 0.25 -0.08"/>
    </body>

    <!-- Shelf / storage rack -->
    <body name="shelf" pos="0.8 0 0">
      <geom name="shelf_base" type="box" size="0.02 0.25 0.2" pos="0 0 0.25" material="shelf_mat"/>
      <geom name="shelf_back" type="box" size="0.15 0.02 0.25" pos="0 0.25 0.3" material="shelf_mat"/>
      <geom name="shelf_shelf1" type="box" size="0.15 0.25 0.02" pos="0 0 0.15" material="shelf_mat"/>
      <geom name="shelf_shelf2" type="box" size="0.15 0.25 0.02" pos="0 0 0.35" material="shelf_mat"/>
    </body>

    <!-- PICKUP OBJECTS (colored cubes on table) -->
    <body name="cube_red" pos="0.5 0.18 0.16">
      <freejoint name="cube_red_joint"/>
      <geom name="cube_red_geom" type="box" size="0.025 0.025 0.025" material="red_mat"/>
      <site name="cube_red_site" pos="0 0 0" size="0.001 0.001 0.001" group="4"/>
    </body>

    <body name="cube_green" pos="0.6 0.1 0.16">
      <freejoint name="cube_green_joint"/>
      <geom name="cube_green_geom" type="box" size="0.025 0.025 0.025" material="green_mat"/>
      <site name="cube_green_site" pos="0 0 0" size="0.001 0.001 0.001" group="4"/>
    </body>

    <body name="cube_blue" pos="0.45 -0.12 0.16">
      <freejoint name="cube_blue_joint"/>
      <geom name="cube_blue_geom" type="box" size="0.025 0.025 0.025" material="blue_mat"/>
      <site name="cube_blue_site" pos="0 0 0" size="0.001 0.001 0.001" group="4"/>
    </body>

    <body name="cube_yellow" pos="0.55 -0.2 0.16">
      <freejoint name="cube_yellow_joint"/>
      <geom name="cube_yellow_geom" type="box" size="0.025 0.025 0.025" material="yellow_mat"/>
      <site name="cube_yellow_site" pos="0 0 0" size="0.001 0.001 0.001" group="4"/>
    </body>

    <!-- TARGET ZONES (drop-off locations) -->
    <body name="target_red" pos="0.3 0.25 0.01">
      <geom name="target_red_geom" type="box" size="0.05 0.05 0.005" material="target_red"/>
    </body>
    <body name="target_green" pos="0.5 0.25 0.01">
      <geom name="target_green_geom" type="box" size="0.05 0.05 0.005" material="target_green"/>
    </body>
    <body name="target_blue" pos="0.4 -0.25 0.01">
      <geom name="target_blue_geom" type="box" size="0.05 0.05 0.005" material="target_blue"/>
    </body>
    <body name="target_yellow" pos="0.2 -0.25 0.01">
      <geom name="target_yellow_geom" type="box" size="0.05 0.05 0.005" material="target_yellow"/>
    </body>
  </worldbody>
</mujoco>
