<mujoco model="panda_pickplace">
  <include file="assets/panda.xml"/>

  <statistic center="0.4 0 0.4" extent="1.0"/>

  <visual>
    <headlight diffuse="0.9 0.9 0.9" ambient="0.5 0.5 0.5" specular="0 0 0"/>
    <rgba haze="0.1 0.15 0.2 1"/>
    <global azimuth="130" elevation="-25" offwidth="1280" offheight="720"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.35 0.5 0.7" rgb2="0.02 0.02 0.05" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
      rgb1="0.25 0.3 0.35" rgb2="0.12 0.14 0.16" markrgb="0.6 0.6 0.6" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="6 6" reflectance="0.1"/>
    <material name="table_mat" rgba="0.3 0.27 0.24 1" specular="0.3"/>
    <material name="obj_red" rgba="0.95 0.15 0.1 1" specular="0.4"/>
    <material name="obj_green" rgba="0.1 0.95 0.1 1" specular="0.4"/>
    <material name="obj_blue" rgba="0.1 0.15 0.95 1" specular="0.4"/>
    <material name="obj_yellow" rgba="0.95 0.95 0.1 1" specular="0.4"/>
    <material name="tgt_red" rgba="0.95 0.15 0.1 0.15"/>
    <material name="tgt_green" rgba="0.1 0.95 0.1 0.15"/>
    <material name="tgt_blue" rgba="0.1 0.15 0.95 0.15"/>
    <material name="tgt_yellow" rgba="0.95 0.95 0.1 0.15"/>
  </asset>

  <worldbody>
    <light pos="1.5 1.5 2.5" dir="-0.5 -0.5 -1" directional="true" diffuse="0.5 0.5 0.5"/>
    <light pos="-0.5 1.5 2" dir="0.5 -0.5 -1" directional="true" diffuse="0.3 0.3 0.3"/>
    <light pos="0.3 0 2" dir="0 0 -1" directional="true" diffuse="0.2 0.2 0.2"/>

    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Table -->
    <body name="worktable" pos="0.5 0 0">
      <geom name="table_top" type="box" size="0.35 0.25 0.025" pos="0 0 0.075" material="table_mat"/>
    </body>

    <!-- 4 color cubes on table -->
    <body name="cube_red" pos="0.50 0.15 0.11">
      <freejoint/>
      <geom type="box" size="0.025 0.025 0.025" material="obj_red"/>
    </body>
    <body name="cube_green" pos="0.55 0.05 0.11">
      <freejoint/>
      <geom type="box" size="0.025 0.025 0.025" material="obj_green"/>
    </body>
    <body name="cube_blue" pos="0.50 -0.15 0.11">
      <freejoint/>
      <geom type="box" size="0.025 0.025 0.025" material="obj_blue"/>
    </body>
    <body name="cube_yellow" pos="0.55 -0.05 0.11">
      <freejoint/>
      <geom type="box" size="0.025 0.025 0.025" material="obj_yellow"/>
    </body>

    <!-- Target zones -->
    <body name="target_red" pos="0.30 0.20 0.01">
      <geom type="box" size="0.04 0.04 0.005" material="tgt_red"/>
    </body>
    <body name="target_green" pos="0.40 0.20 0.01">
      <geom type="box" size="0.04 0.04 0.005" material="tgt_green"/>
    </body>
    <body name="target_blue" pos="0.30 -0.20 0.01">
      <geom type="box" size="0.04 0.04 0.005" material="tgt_blue"/>
    </body>
    <body name="target_yellow" pos="0.40 -0.20 0.01">
      <geom type="box" size="0.04 0.04 0.005" material="tgt_yellow"/>
    </body>
  </worldbody>
</mujoco>
