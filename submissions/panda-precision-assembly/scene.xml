<mujoco model="panda_demo">
  <include file="assets/panda.xml"/>

  <statistic center="0.3 0 0.3" extent="0.8"/>

  <visual>
    <headlight diffuse="0.8 0.8 0.8" ambient="0.5 0.5 0.5" specular="0 0 0"/>
    <rgba haze="0.1 0.15 0.2 1"/>
    <global azimuth="135" elevation="-30" offwidth="1280" offheight="720"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
      rgb1="0.2 0.3 0.4" rgb2="0.1 0.15 0.2" markrgb="0.7 0.7 0.7" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.1"/>
    <material name="table" rgba="0.25 0.22 0.2 1" specular="0.3"/>
    <material name="red" rgba="0.9 0.1 0.1 1"/>
    <material name="green" rgba="0.1 0.9 0.1 1"/>
    <material name="blue" rgba="0.1 0.1 0.9 1"/>
    <material name="yellow" rgba="0.9 0.9 0.1 1"/>
  </asset>

  <worldbody>
    <light pos="1 1 2" dir="-0.5 -0.5 -1" directional="true" diffuse="0.5 0.5 0.5"/>
    <light pos="-0.5 1 1.5" dir="0.5 -0.5 -1" directional="true" diffuse="0.3 0.3 0.3"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Table -->
    <body name="table" pos="0.4 0 0">
      <geom name="table_top" type="box" size="0.25 0.2 0.025" pos="0 0 0.075" material="table"/>
    </body>

    <!-- 4 colored objects on table -->
    <body name="obj_red" pos="0.40 0.12 0.105">
      <freejoint/>
      <geom type="box" size="0.025 0.025 0.025" material="red"/>
    </body>
    <body name="obj_green" pos="0.50 0.12 0.105">
      <freejoint/>
      <geom type="cylinder" size="0.025 0.025" material="green"/>
    </body>
    <body name="obj_blue" pos="0.40 -0.12 0.105">
      <freejoint/>
      <geom type="sphere" size="0.025" material="blue"/>
    </body>
    <body name="obj_yellow" pos="0.50 -0.12 0.105">
      <freejoint/>
      <geom type="box" size="0.025 0.025 0.025" material="yellow"/>
    </body>

    <!-- Target zones -->
    <body name="target_red" pos="0.28 0.16 0.01">
      <geom type="box" size="0.04 0.04 0.005" rgba="0.9 0.1 0.1 0.2"/>
    </body>
    <body name="target_green" pos="0.28 -0.16 0.01">
      <geom type="box" size="0.04 0.04 0.005" rgba="0.1 0.9 0.1 0.2"/>
    </body>
    <body name="target_blue" pos="0.52 0.16 0.01">
      <geom type="box" size="0.04 0.04 0.005" rgba="0.1 0.1 0.9 0.2"/>
    </body>
    <body name="target_yellow" pos="0.52 -0.16 0.01">
      <geom type="box" size="0.04 0.04 0.005" rgba="0.9 0.9 0.1 0.2"/>
    </body>
  </worldbody>
</mujoco>
